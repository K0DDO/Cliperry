###############################################################################
# Cliperry — PRODUCTION environment template
#
#   cp .env.production.example .env.production
#   # edit every CHANGE_ME value
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Never commit a real .env.production file.
###############################################################################

# --- Application ---
APP_NAME=Cliperry
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
API_PREFIX=/api
API_VERSION=0.1.0

# --- HTTP ---
HOST=0.0.0.0
PORT=8000
# Comma-separated public hostnames (no wildcards in production)
TRUSTED_HOSTS=api.example.com,www.example.com
# Required behind nginx / Traefik / Cloudflare
TRUST_PROXY_HEADERS=true

# --- Database (compose injects host; keep credentials in sync) ---
POSTGRES_USER=cliperry
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=cliperry
DATABASE_URL=postgresql+asyncpg://cliperry:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/cliperry
DATABASE_URL_SYNC=postgresql+psycopg2://cliperry:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/cliperry

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
REDIS_MAXMEMORY=256mb
CELERY_CONCURRENCY=2
CELERY_LOG_LEVEL=WARNING
CELERY_MAX_TASKS_PER_CHILD=50

# --- Storage ---
TEMP_DIR=/tmp/cliperry
TEMP_FILE_TTL_SECONDS=1800

# --- yt-dlp (recommended on datacenter IPs) ---
YTDLP_COOKIES_FROM_BROWSER=
# Mount cookies into /app/cookies via cookies_data volume
YTDLP_COOKIES_FILE=
YTDLP_PROXY=

# --- Rate limits ---
RATE_LIMIT_ANALYZE=30
RATE_LIMIT_DOWNLOAD=15
RATE_LIMIT_HISTORY=60
RATE_LIMIT_TASKS=120
RATE_LIMIT_ADMIN_LOGIN=5
RATE_LIMIT_IP_GLOBAL=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_WS=30
WS_MAX_SESSION_SECONDS=900
WS_DB_FALLBACK_SECONDS=10
DOWNLOAD_MAX_FILESIZE_BYTES=2147483648

# --- Security / CORS ---
ENABLE_WORKER_TEST=false
# Public web origins only (no * )
CORS_ORIGINS=https://example.com
# Required for Chrome Extension in production (extension id or full origin)
CORS_EXTENSION_IDS=CHANGE_ME_EXTENSION_ID

# --- Public URL (Telegram bot / signed links) ---
BACKEND_PUBLIC_URL=https://api.example.com
BACKEND_HOST_PORT=8000
# Full image ref used by CD (GHCR). Local builds can omit this.
# CLIPERRY_IMAGE=ghcr.io/OWNER/REPO/cliperry-backend:latest
CLIPERRY_IMAGE=cliperry-backend:latest

# --- Admin ---
ADMIN_USERNAME=admin
# Min 12 chars; avoid defaults like change-me / admin / password
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD_12PLUS

# --- Telegram bot (optional; enable profile: docker compose --profile bot ...) ---
TELEGRAM_BOT_TOKEN=
