# Development template. For production see: .env.production.example
# Application
APP_NAME=Cliperry
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=replace-with-at-least-32-random-characters
API_PREFIX=/api
API_VERSION=0.1.0

# Server
HOST=0.0.0.0
PORT=8000
# Production: set explicit hosts, e.g. api.cliperry.app,localhost
TRUSTED_HOSTS=*

# Database
DATABASE_URL=postgresql+asyncpg://cliperry:cliperry@postgres:5432/cliperry
DATABASE_URL_SYNC=postgresql+psycopg2://cliperry:cliperry@postgres:5432/cliperry

# Redis
REDIS_URL=redis://redis:6379/0

# Celery (Phase 2+)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Temporary file storage
TEMP_DIR=/tmp/cliperry
TEMP_FILE_TTL_SECONDS=1800

# yt-dlp (optional — helps when YouTube requires auth / cookies)
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_COOKIES_FILE=
YTDLP_PROXY=

# Rate limiting
RATE_LIMIT_ANALYZE=30
RATE_LIMIT_DOWNLOAD=15
RATE_LIMIT_HISTORY=60
RATE_LIMIT_TASKS=120
RATE_LIMIT_ADMIN_LOGIN=10
RATE_LIMIT_IP_GLOBAL=180
RATE_LIMIT_WINDOW_SECONDS=60

# Security
# Trust X-Forwarded-For only behind a known reverse proxy
TRUST_PROXY_HEADERS=false
# Comma-separated Chrome extension IDs (required in production for extension CORS)
CORS_EXTENSION_IDS=
# Disable in production (enforced)
ENABLE_WORKER_TEST=true

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=
BACKEND_PUBLIC_URL=http://backend:8000

# Admin panel (/admin) — change password before production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
